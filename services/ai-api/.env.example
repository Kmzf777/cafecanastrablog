# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Supabase (service role — bypasses RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth — shared secret between Vercel frontend and this API
AI_API_SECRET=generate-a-strong-random-secret-here

# Domain for Traefik (used in docker-compose labels)
DOMAIN=canastrainteligencia.com

# Server
PORT=3100
